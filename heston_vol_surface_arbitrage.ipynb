    "---\n",
    "## 3. Surface Construction\n",
    "\n",
    "Build a 2D implied volatility surface (strike × time-to-expiry). We use calls for strikes ≥ ATM and puts for strikes < ATM (out-of-the-money options are more liquid)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_iv_surface(df):\n",
    "    \"\"\"\n",
    "    Construct a clean IV surface DataFrame.\n",
    "    \n",
    "    Strategy: use OTM options (calls for K > F, puts for K < F)\n",
    "    because they are more liquid and have cleaner implied vols.\n",
    "    \"\"\"\n",
    "    df = df.copy()\n",
    "    \n",
    "    # Parse expiry and compute TTE\n",
    "    df['expiry_dt'] = pd.to_datetime(df['expiry'])\n",
    "    df['TTE'] = (df['expiry_dt'] - pd.Timestamp.today()).dt.days / 365.0\n",
    "    df['TTE'] = df['TTE'].clip(lower=1/365)  # Minimum 1 day\n",
    "    \n",
    "    S = df['underlying_price'].iloc[0]\n",
    "    r = RISK_FREE_RATE\n",
    "    q = DIVIDEND_YIELD\n",
    "    \n",
    "    # Forward price\n",
    "    df['forward'] = S * np.exp((r - q) * df['TTE'])\n",
    "    df['moneyness'] = df['strike'] / df['forward']\n",
    "    df['log_moneyness'] = np.log(df['moneyness'])\n",
    "    \n",
    "    # Use mid-price IV\n",
    "    # yfinance already provides impliedVol; we also compute from mid-price when available\n",
    "    df['mid'] = (df['bid'] + df['ask']) / 2\n",
    "    df['mid_iv'] = np.nan\n",
    "    \n",
    "    for idx, row in df.iterrows():\n",
    "        if HAVE_PY_VOLLIB and row['mid'] > 0:\n",
    "            try:\n",
    "                iv = bs_iv(row['mid'], S, row['strike'], row['TTE'], r, row['option_type'].upper()[0])\n",
    "                df.at[idx, 'mid_iv'] = iv\n",
    "            except:\n",
    "                df.at[idx, 'mid_iv'] = row['impliedVol']\n",
    "        else:\n",
    "            df.at[idx, 'mid_iv'] = row['impliedVol']\n",
    "    \n",
    "    # Select OTM options for the surface: \n",
    "    # OTM call = strike > forward, OTM put = strike < forward\n",
    "    otm_calls = (df['option_type'] == 'call') & (df['strike'] > df['forward'])\n",
    "    otm_puts = (df['option_type'] == 'put') & (df['strike'] < df['forward'])\n",
    "    atm = (df['option_type'] == 'call') & (df['strike'] == df['forward'].round(-1))  # Nearest to ATM\n",
    "    surface_df = df[otm_calls | otm_puts | atm].copy()\n",
    "    \n",
    "    print(f'Surface built: {len(surface_df)} OTM options across {surface_df[\"expiry\"].nunique()} expiries')\n",
    "    return surface_df\n",
    "\n",
    "\n",
    "surface = build_iv_surface(data)\n",
    "print(f'\\nSample surface data:')\n",
    "surface[['expiry', 'strike', 'option_type', 'mid_iv', 'TTE', 'moneyness']].head(10)"
   ]
  },
