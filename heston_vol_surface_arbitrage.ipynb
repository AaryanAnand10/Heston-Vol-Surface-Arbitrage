    "    all_pnls = []\n",
    "    for i in range(n_trades):\n",
    "        trade = trades_df.iloc[i]\n",
    "        pnl = simulate_delta_hedged_straddle(trade, S0, r, q, heston_params, n_days=days_per_trade)\n",
    "        pnl['trade_id'] = i\n",
    "        pnl['strike'] = trade['strike']\n",
    "        pnl['action'] = trade['action']\n",
    "        all_pnls.append(pnl)\n",
    "    \n",
    "    if not all_pnls:\n",
    "        return pd.DataFrame()\n",
    "    \n",
    "    return pd.concat(all_pnls, ignore_index=True)\n",
    "\n",
    "\n",
    "if len(trades) > 0:\n",
    "    multi_pnl = run_multi_trade_backtest(trades, S, r, q, heston_params, days_per_trade=5)\n",
    "    \n",
    "    if len(multi_pnl) > 0:\n",
    "        fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
