    "---\n",
    "## 9. Backtest Simulation & P&L Attribution\n",
    "\n",
    "Simulate a delta-hedged straddle over a single holding period and attribute P&L into:\n",
    "- **Volatility capture**: gain/loss from the difference between implied and realized vol\n",
    "- **Delta drift**: P&L from delta position × underlying move (should be near zero if hedged daily)\n",
    "- **Gamma scalping**: convexity benefit from rebalancing\n",
    "- **Theta decay**: time decay of the option position"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def simulate_delta_hedged_straddle(trade_row, S0, r, q, heston_params, n_days=5):\n",
    "    \"\"\"\n",
    "    Simulate a delta-hedged straddle over n_days.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    trade_row : Series with trade parameters\n",
    "    S0 : Initial underlying price\n",
    "    r, q : Rates\n",
    "    heston_params : Dict of calibrated Heston params\n",
    "    n_days : Number of days to simulate\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    DataFrame with daily P&L breakdown\n",
    "    \"\"\"\n",
    "    np.random.seed(42)\n",
    "    \n",
    "    K = trade_row['strike']\n",
    "    T = trade_row['TTE']\n",
    "    direction = trade_row['direction']\n",
    "    \n",
    "    # Draw from Heston for realistic price paths\n",
    "    kappa = heston_params['kappa']\n",
    "    theta = heston_params['theta']\n",
    "    xi = heston_params['xi']\n",
    "    rho = heston_params['rho']\n",
    "    v0 = heston_params['v0']\n",
    "    \n",
    "    dt = 1/252  # Daily timestep\n",
    "    \n",
    "    results = []\n",
    "    S = S0\n",
    "    v = v0\n",
    "    \n",
    "    # Initial option prices and greeks (using Black-Scholes greeks as approximation)\n",
    "    def straddle_value(S_cur, v_cur, t_remaining):\n",
    "        \"\"\"Compute straddle value given current state.\"\"\"\n",
    "        iv_cur, _ = heston_iv(S_cur, K, t_remaining, r, q,\n",
    "                              kappa, theta, xi, rho, v_cur, 'call')\n",
    "        \n",
    "        # BS Greeks approximation\n",
    "        sigma = max(iv_cur, 0.001)\n",
    "        d1 = (np.log(S_cur / K) + (r - q + 0.5 * sigma**2) * t_remaining) / (sigma * np.sqrt(t_remaining))\n",
    "        d2 = d1 - sigma * np.sqrt(t_remaining)\n",
    "        \n",
    "        call = S_cur * np.exp(-q * t_remaining) * norm.cdf(d1) - K * np.exp(-r * t_remaining) * norm.cdf(d2)\n",
    "        put = K * np.exp(-r * t_remaining) * norm.cdf(-d2) - S_cur * np.exp(-q * t_remaining) * norm.cdf(-d1)\n",
    "        \n",
    "        delta_call = np.exp(-q * t_remaining) * norm.cdf(d1)\n",
    "        delta_put = np.exp(-q * t_remaining) * (norm.cdf(d1) - 1)\n",
    "        gamma = np.exp(-q * t_remaining) * norm.pdf(d1) / (S_cur * sigma * np.sqrt(t_remaining))\n",
    "        \n",
    "        return {\n",
    "            'straddle': call + put,\n",
    "            'delta': delta_call + delta_put,\n",
    "            'gamma': gamma * 2,\n",
    "            'vega': S_cur * np.exp(-q * t_remaining) * norm.pdf(d1) * np.sqrt(t_remaining) * 2,\n",
    "            'theta': 0,  # Simplified: computed via finite difference\n",
    "        }\n",
    "    \n",
    "    # Initial position\n",
    "    initial = straddle_value(S, v, T)\n",
    "    \n",
    "    # Hedge position: short delta shares\n",
    "    hedge_amount = -initial['delta'] * direction\n",
    "    \n",
    "    # Tracking variables\n",
    "    straddle_pos = direction  # +1 for long, -1 for short\n",
    "    hedge_pos = 0  # Cumulative shares short\n",
    "    cash = 0\n",
    "    \n",
    "    # Initial setup\n",
    "    entry_cost = initial['straddle'] * direction\n",
    "    cash -= entry_cost  # Paid to enter straddle\n",
    "    cash += hedge_amount * S  # Short shares → receive cash\n",
    "    hedge_pos = -hedge_amount\n",
    "    \n",
    "    results.append({\n",
    "        'day': 0,\n",
    "        'S': S,\n",
    "        'straddle_value': initial['straddle'] * direction,\n",
    "        'delta': initial['delta'] * direction,\n",
    "        'gamma': initial['gamma'] * direction,\n",
    "        'hedge_pnl': 0.0,\n",
    "        'option_pnl': 0.0,\n",
    "        'total_pnl': 0.0,\n",
    "        'variance_realized': 0.0,\n",
    "    })\n",
    "    \n",
    "    for day in range(1, min(n_days + 1, int(T * 365))):\n",
    "        t_remaining = max(T - day / 365, 1/365)\n",
    "        \n",
    "        # Simulate Heston path for one day\n",
    "        z1 = np.random.normal()\n",
    "        z2 = np.random.normal()\n",
    "        dwS = np.sqrt(dt) * z1\n",
    "        dwV = np.sqrt(dt) * (rho * z1 + np.sqrt(1 - rho**2) * z2)\n",
    "        \n",
    "        v_prev = v\n",
    "        v = v + kappa * (theta - v) * dt + xi * np.sqrt(max(v, 0)) * dwV\n",
    "        v = max(v, 1e-6)  # Keep positive\n",
    "        \n",
    "        dS = S * (0.15 * dt + np.sqrt(max(v_prev, 0)) * dwS)  # Drift ~15% annual\n",
    "        S_new = S + dS\n",
    "        S_new = max(S_new, 1.0)\n",
    "        \n",
    "        realized_return = dS / S\n",
    "        \n",
    "        # New straddle value\n",
    "        current = straddle_value(S_new, v, t_remaining)\n",
    "        \n",
    "        # P&L components\n",
    "        option_value_change = (current['straddle'] * direction) - results[-1]['straddle_value']\n",
    "        hedge_pnl_change = hedge_pos * (S - S_new)  # Short hedge → gain when price drops\n",
    "        \n",
    "        # Gamma scalping approximation: 0.5 * gamma * S^2 * (dS/S)^2\n",
    "        gamma_scalp = 0.5 * (results[-1]['gamma'] / direction) * S**2 * (realized_return)**2 if direction != 0 else 0\n",
    "        \n",
    "        # Variance capture\n",
    "        variance_realized = realized_return**2 / dt  # Annualized realized variance\n",
    "        \n",
    "        # Update hedge position to new delta\n",
    "        new_hedge = -current['delta'] * direction\n",
    "        hedge_adjustment = new_hedge - hedge_pos\n",
    "        cash -= hedge_adjustment * S_new  # Buy or sell shares\n",
    "        hedge_pos = new_hedge\n",
    "        \n",
    "        total_pnl = option_value_change + hedge_pnl_change\n",
    "        \n",
    "        results.append({\n",
    "            'day': day,\n",
    "            'S': S_new,\n",
    "            'v': v,\n",
    "            'straddle_value': current['straddle'] * direction,\n",
    "            'delta': current['delta'] * direction,\n",
    "            'gamma': current['gamma'] * direction,\n",
    "            'option_pnl': option_value_change,\n",
    "            'hedge_pnl': hedge_pnl_change,\n",
    "            'gamma_scalp': gamma_scalp,\n",
    "            'total_pnl': total_pnl,\n",
    "            'cumulative_pnl': sum([r['total_pnl'] for r in results]) + total_pnl,\n",
    "            'variance_realized': variance_realized * 100,  # As percentage\n",
    "        })\n",
    "        \n",
    "        S = S_new\n",
    "    \n",
    "    return pd.DataFrame(results)\n",
    "\n",
    "\n",
    "# Run simulation on the first trade (if any exist)\n",
    "if len(trades) > 0:\n",
    "    best_trade = trades.iloc[0]\n",
    "    print(f'Simulating delta-hedged straddle for {best_trade[\"action\"]} at K={best_trade[\"strike\"]}, expiry={best_trade[\"expiry\"]}')\n",
    "    pnl_df = simulate_delta_hedged_straddle(best_trade, S, r, q, heston_params, n_days=10)\n",
    "    display(pnl_df)\n",
    "else:\n",
    "    print('No trades to simulate.')\n",
    "    # Create a dummy trade for demonstration\n",
    "    dummy_trade = pd.Series({\n",
    "        'strike': 500.0,\n",
    "        'TTE': 0.25,\n",
    "        'direction': 1,  # Long straddle\n",
    "        'action': 'BUY',\n",
    "        'mispricing_type': 'underpriced',\n",
    "    })\n",
    "    print('Running demo simulation on ATM straddle...')\n",
    "    pnl_df = simulate_delta_hedged_straddle(dummy_trade, S, r, q, heston_params, n_days=10)\n",
    "    display(pnl_df)"
   ]
